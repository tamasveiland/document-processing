# ─────────────────────────────────────────────────────────────────────────────
# Environment template for document-processing / src
#
# Copy this file to .env and fill in the values for your deployment.
# Values are populated automatically when you run `azd env get-values` or
# `azd up` from the repository root.
#
# Authentication uses DefaultAzureCredential — no API keys are required.
# Run `az login` (or set up a managed identity) before running the script.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required by process_document.py ─────────────────────────────────────────

# Endpoint of the Azure Content Understanding (AI Services) resource.
# Found in the Azure portal under your Cognitive Services account → Keys and Endpoint.
AZURE_CONTENT_UNDERSTANDING_ENDPOINT="https://<your-cu-resource>.cognitiveservices.azure.com/"

# ── Azure AI Foundry project ─────────────────────────────────────────────────

AZURE_AI_ACCOUNT_ID="/subscriptions/<subscription-id>/resourceGroups/<rg>/providers/Microsoft.CognitiveServices/accounts/<ai-account-name>"
AZURE_AI_ACCOUNT_NAME="<ai-account-name>"
AZURE_AI_FOUNDRY_PROJECT_ID="/subscriptions/<subscription-id>/resourceGroups/<rg>/providers/Microsoft.CognitiveServices/accounts/<ai-account-name>/projects/<project-name>"
AZURE_AI_PROJECT_ENDPOINT="https://<ai-account-name>.services.ai.azure.com/api/projects/<project-name>"
AZURE_AI_PROJECT_ID="/subscriptions/<subscription-id>/resourceGroups/<rg>/providers/Microsoft.CognitiveServices/accounts/<ai-account-name>/projects/<project-name>"
AZURE_AI_PROJECT_NAME="<project-name>"
AZURE_AI_PROJECT_ACR_CONNECTION_NAME=""

# ── Content Understanding connection ────────────────────────────────────────

AZURE_CONTENT_UNDERSTANDING_CONNECTION_NAME="content-understanding-connection"
AZURE_CONTENT_UNDERSTANDING_ENDPOINT="https://<your-cu-resource>.cognitiveservices.azure.com/"
AZURE_CONTENT_UNDERSTANDING_NAME="<your-cu-resource>"

# ── Document Intelligence (optional — for other processing steps) ────────────

AZURE_DOCUMENT_INTELLIGENCE_CONNECTION_NAME="doc-intelligence-connection"
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT="https://<your-di-resource>.cognitiveservices.azure.com/"
AZURE_DOCUMENT_INTELLIGENCE_NAME="<your-di-resource>"

# ── Azure OpenAI ─────────────────────────────────────────────────────────────

AZURE_OPENAI_ENDPOINT="https://<ai-account-name>.openai.azure.com/"

# ── Azure AI Search (optional) ───────────────────────────────────────────────

AZURE_AI_SEARCH_CONNECTION_NAME=""
AZURE_AI_SEARCH_SERVICE_NAME=""

# ── Storage (optional) ───────────────────────────────────────────────────────

AZURE_STORAGE_ACCOUNT_NAME=""
AZURE_STORAGE_CONNECTION_NAME=""

# ── Bing grounding (optional) ────────────────────────────────────────────────

BING_GROUNDING_CONNECTION_ID=""
BING_GROUNDING_CONNECTION_NAME=""
BING_GROUNDING_RESOURCE_NAME=""
BING_CUSTOM_GROUNDING_CONNECTION_ID=""
BING_CUSTOM_GROUNDING_CONNECTION_NAME=""
BING_CUSTOM_GROUNDING_NAME=""

# ── Application Insights (optional) ─────────────────────────────────────────

APPLICATIONINSIGHTS_CONNECTION_STRING=""
APPLICATIONINSIGHTS_RESOURCE_ID=""

# ── Azure environment metadata ───────────────────────────────────────────────

AZURE_ENV_NAME="<azd-env-name>"
AZURE_LOCATION="<azure-region>"          # e.g. swedencentral
AZURE_RESOURCE_GROUP="<resource-group>"
AZURE_SUBSCRIPTION_ID="<subscription-id>"
AZURE_CONTAINER_REGISTRY_ENDPOINT=""

# ── AI project dependent resources (set by azd) ──────────────────────────────

AI_PROJECT_CONNECTION_IDS_JSON="[]"
AI_PROJECT_DEPENDENT_RESOURCES="[]"
AI_PROJECT_DEPLOYMENTS="[]"
